---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Em Breve – Clube de Desbravadores Falcão Negro" description="O site do Clube de Desbravadores Falcão Negro está chegando. Fique atento às novidades!">

  <div class="coming-soon">
    <div class="cs-particles" id="csParticles"></div>
    <div class="cs-bg"></div>

    <div class="cs-content">

      <!-- LOGO -->
      <div class="cs-logo animate-in">
        <img src="/images/logo-completo.png" alt="Clube de Desbravadores Falcão Negro" width="160" height="160" />
      </div>

      <!-- EYEBROW -->
      <p class="cs-eyebrow animate-in" style="animation-delay:.15s">Clube de Desbravadores</p>

      <!-- TÍTULO -->
      <h1 class="cs-title animate-in" style="animation-delay:.25s">
        FALCÃO <span>NEGRO</span>
      </h1>

      <p class="cs-sub animate-in" style="animation-delay:.35s">Cascavel – Paraná</p>

      <!-- MENSAGEM -->
      <p class="cs-msg animate-in" style="animation-delay:.45s">
        Algo grandioso está chegando.<br>Estamos preparando tudo para você!
      </p>

      <!-- VERSÍCULO -->
      <blockquote class="cs-verse animate-in" style="animation-delay:.55s">
        "Mas os que esperam no SENHOR renovarão as suas forças;<br>
        subirão com asas como águias."
        <cite>— Isaías 40:31</cite>
      </blockquote>

      <!-- CONTADOR -->
      <div class="cs-countdown animate-in" style="animation-delay:.65s">
        <div class="countdown-block">
          <span class="countdown-num" id="cdDias">14</span>
          <span class="countdown-label">Dias</span>
        </div>
        <div class="countdown-sep">:</div>
        <div class="countdown-block">
          <span class="countdown-num" id="cdHoras">00</span>
          <span class="countdown-label">Horas</span>
        </div>
        <div class="countdown-sep">:</div>
        <div class="countdown-block">
          <span class="countdown-num" id="cdMin">00</span>
          <span class="countdown-label">Minutos</span>
        </div>
        <div class="countdown-sep">:</div>
        <div class="countdown-block">
          <span class="countdown-num" id="cdSeg">00</span>
          <span class="countdown-label">Segundos</span>
        </div>
      </div>

      <!-- BARRA DE PROGRESSO -->
      <div class="cs-progress animate-in" style="animation-delay:.75s">
        <div class="progress-header">
          <span>Progresso do site</span>
          <span class="progress-pct">75%</span>
        </div>
        <div class="progress-track">
          <div class="progress-bar" id="progressBar"></div>
        </div>
      </div>

      <!-- BOTÕES -->
      <div class="cs-buttons animate-in" style="animation-delay:.85s">
        <a href="https://wa.me/5545999981196" target="_blank" rel="noopener" class="cs-btn cs-btn--primary">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
          Fale pelo WhatsApp
        </a>
        <a href="https://instagram.com/dbv_falcaonegro" target="_blank" rel="noopener" class="cs-btn cs-btn--outline">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          Seguir no Instagram
        </a>
      </div>

      <!-- FOOTER -->
      <p class="cs-footer animate-in" style="animation-delay:.95s">
        © 2026 Clube de Desbravadores Falcão Negro – Cascavel, PR
      </p>

    </div>
  </div>

</Layout>

<style>
  /* esconde navbar e trava scroll nesta página */
  :global(#navbar) { display: none !important; }
  :global(html), :global(body) { overflow: hidden; height: 100%; }

  .coming-soon {
    position: relative;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem 1rem;
    overflow: hidden;
  }

  .cs-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 20% 20%, rgba(249,115,22,0.12) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 80%, rgba(194,87,26,0.10) 0%, transparent 50%),
      #0a0a0a;
    z-index: 0;
  }

  .cs-particles {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  /* partícula (reutiliza a mesma lógica do hero) */
  .cs-particle {
    position: absolute;
    border-radius: 50%;
    background: #F97316;
    opacity: 0;
    animation: csFloat linear infinite;
  }
  @keyframes csFloat {
    0%   { opacity: 0; transform: translateY(0) translateX(0); }
    10%  { opacity: 0.7; }
    90%  { opacity: 0.3; }
    100% { opacity: 0; transform: translateY(-110vh) translateX(var(--drift)); }
  }

  /* conteúdo */
  .cs-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 680px;
    width: 100%;
    gap: 0;
  }

  /* animação de entrada */
  .animate-in {
    opacity: 0;
    transform: translateY(24px);
    animation: csIn 0.7s ease forwards;
  }
  @keyframes csIn {
    to { opacity: 1; transform: translateY(0); }
  }

  /* logo */
  .cs-logo {
    margin-bottom: 0.75rem;
  }
  .cs-logo img {
    width: 100px;
    height: 100px;
    filter: drop-shadow(0 0 30px rgba(249,115,22,0.35));
    animation: floatLogo 5s ease-in-out infinite;
  }
  @keyframes floatLogo {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-10px); }
  }

  /* textos */
  .cs-eyebrow {
    font-family: 'Oswald', sans-serif;
    font-size: 0.85rem;
    letter-spacing: 5px;
    text-transform: uppercase;
    color: #F97316;
    margin-bottom: 0.5rem;
  }

  .cs-title {
    font-family: 'Oswald', sans-serif;
    font-size: clamp(3.5rem, 10vw, 7rem);
    font-weight: 700;
    line-height: 0.95;
    text-transform: uppercase;
    letter-spacing: -2px;
    color: #fff;
    margin-bottom: 0.4rem;
  }
  .cs-title span { color: #F97316; text-shadow: 0 0 40px rgba(249,115,22,0.4); }

  .cs-sub {
    font-family: 'Oswald', sans-serif;
    font-size: 1rem;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: #666;
    margin-bottom: 0.75rem;
  }

  .cs-msg {
    font-size: 1rem;
    color: #ccc;
    line-height: 1.6;
    margin-bottom: 0.75rem;
  }

  .cs-verse {
    border-left: 3px solid #F97316;
    padding-left: 1.25rem;
    text-align: left;
    margin: 0 0 1.25rem;
    font-style: italic;
    color: #aaa;
    font-size: 0.95rem;
    line-height: 1.7;
  }
  .cs-verse cite {
    display: block;
    margin-top: 0.5rem;
    color: #F97316;
    font-style: normal;
    font-family: 'Oswald', sans-serif;
    font-size: 0.85rem;
    letter-spacing: 1px;
  }

  /* CONTADOR */
  .cs-countdown {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }
  .countdown-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    background: #111;
    border: 1px solid rgba(249,115,22,0.2);
    border-radius: 10px;
    padding: 0.75rem 1.25rem;
    min-width: 72px;
  }
  .countdown-num {
    font-family: 'Oswald', sans-serif;
    font-size: 2.2rem;
    font-weight: 700;
    color: #F97316;
    line-height: 1;
    letter-spacing: -1px;
    transition: transform 0.15s;
  }
  .countdown-num.tick {
    transform: scale(1.15);
  }
  .countdown-label {
    font-size: 0.7rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #555;
    margin-top: 0.4rem;
    font-family: 'Oswald', sans-serif;
  }
  .countdown-sep {
    font-family: 'Oswald', sans-serif;
    font-size: 2.5rem;
    font-weight: 700;
    color: #F97316;
    opacity: 0.5;
    margin-bottom: 1.2rem;
  }

  /* BARRA DE PROGRESSO */
  .cs-progress {
    width: 100%;
    margin-bottom: 1.25rem;
  }
  .progress-header {
    display: flex;
    justify-content: space-between;
    font-size: 0.8rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    font-family: 'Oswald', sans-serif;
    color: #555;
    margin-bottom: 0.6rem;
  }
  .progress-pct { color: #F97316; }
  .progress-track {
    width: 100%;
    height: 6px;
    background: #1a1a1a;
    border-radius: 99px;
    overflow: hidden;
  }
  .progress-bar {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, #c2571a, #F97316, #ffb067);
    border-radius: 99px;
    transition: width 1.8s cubic-bezier(0.22, 1, 0.36, 1);
    box-shadow: 0 0 12px rgba(249,115,22,0.5);
  }

  /* BOTÕES */
  .cs-buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: 1.25rem;
  }
  .cs-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.875rem 1.75rem;
    border-radius: 6px;
    font-family: 'Oswald', sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    text-decoration: none;
    transition: all 0.25s;
    border: 2px solid transparent;
  }
  .cs-btn--primary {
    background: #F97316;
    color: #0a0a0a;
    border-color: #F97316;
  }
  .cs-btn--primary:hover {
    background: #ffb067;
    border-color: #ffb067;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(249,115,22,0.3);
  }
  .cs-btn--outline {
    background: transparent;
    color: #fff;
    border-color: rgba(255,255,255,0.2);
  }
  .cs-btn--outline:hover {
    border-color: #F97316;
    color: #F97316;
    transform: translateY(-2px);
  }

  /* footer */
  .cs-footer {
    font-size: 0.75rem;
    color: #333;
    letter-spacing: 1px;
  }

  /* RESPONSIVO */
  @media (max-width: 500px) {
    .countdown-block { min-width: 60px; padding: 0.75rem 1rem; }
    .countdown-num   { font-size: 2rem; }
    .countdown-sep   { font-size: 1.8rem; }
    .cs-buttons      { flex-direction: column; width: 100%; }
    .cs-btn          { justify-content: center; }
  }
</style>

<script>
  // Partículas
  const container = document.getElementById('csParticles');
  if (container) {
    for (let i = 0; i < 50; i++) {
      const p = document.createElement('div');
      p.className = 'cs-particle';
      const size = Math.random() * 3 + 1;
      p.style.cssText = `
        left: ${Math.random() * 100}%;
        bottom: ${Math.random() * -10}%;
        width: ${size}px;
        height: ${size}px;
        --drift: ${(Math.random() - 0.5) * 200}px;
        animation-duration: ${Math.random() * 12 + 8}s;
        animation-delay: ${Math.random() * 10}s;
      `;
      container.appendChild(p);
    }
  }

  // Countdown — alvo: 5 de abril de 2026 às 00:00
  const target = new Date('2026-04-05T00:00:00').getTime();

  function pad(n: number) { return String(n).padStart(2, '0'); }

  function tick(id: string, val: string) {
    const el = document.getElementById(id);
    if (!el) return;
    if (el.textContent !== val) {
      el.classList.add('tick');
      el.textContent = val;
      setTimeout(() => el.classList.remove('tick'), 150);
    }
  }

  function updateCountdown() {
    const diff = target - Date.now();
    if (diff <= 0) {
      ['cdDias','cdHoras','cdMin','cdSeg'].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.textContent = '00';
      });
      return;
    }
    const d = Math.floor(diff / 86400000);
    const h = Math.floor((diff % 86400000) / 3600000);
    const m = Math.floor((diff % 3600000) / 60000);
    const s = Math.floor((diff % 60000) / 1000);
    tick('cdDias',  pad(d));
    tick('cdHoras', pad(h));
    tick('cdMin',   pad(m));
    tick('cdSeg',   pad(s));
  }

  updateCountdown();
  setInterval(updateCountdown, 1000);

  // Barra de progresso (anima ao carregar)
  setTimeout(() => {
    const bar = document.getElementById('progressBar');
    if (bar) bar.style.width = '75%';
  }, 600);
</script>
